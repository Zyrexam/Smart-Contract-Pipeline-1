# Custom Slither image built on top of the Mythril image so we inherit a working solc binary.
FROM smartbugs/mythril:0.24.7

USER root

ENV SOLC_SELECT_DISABLED=1
ENV SLITHER_DISABLE_SOLC_DOWNLOAD=1
ENV PATH="/usr/local/bin:/root/.solcx/bin:$PATH"

# Install Slither on top of the existing Python + solc toolchain.
RUN python3 -m pip install --no-cache-dir slither-analyzer==0.11.3

WORKDIR /sb

# Verify toolchain
RUN solc --version
RUN slither --version
