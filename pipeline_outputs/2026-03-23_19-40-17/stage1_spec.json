{
  "contract_name": "ERC20Token",
  "contract_type": "ERC20",
  "description": "An ERC20 token with minting and burning functionality.",
  "state_variables": [
    {
      "name": "totalSupply",
      "type": "uint256",
      "visibility": "public",
      "initial_value": "0"
    },
    {
      "name": "balances",
      "type": "mapping(address => uint256)",
      "visibility": "private",
      "initial_value": "{}"
    },
    {
      "name": "allowances",
      "type": "mapping(address => mapping(address => uint256))",
      "visibility": "private",
      "initial_value": "{}"
    }
  ],
  "roles": [
    {
      "name": "owner",
      "permissions": [
        "mint",
        "burn"
      ]
    }
  ],
  "functions": [
    {
      "name": "mint",
      "visibility": "public",
      "inputs": [
        {
          "name": "to",
          "type": "address"
        },
        {
          "name": "amount",
          "type": "uint256"
        }
      ],
      "outputs": [],
      "restricted_to": "owner",
      "description": "Mints new tokens to the specified address, increasing the total supply."
    },
    {
      "name": "burn",
      "visibility": "public",
      "inputs": [
        {
          "name": "from",
          "type": "address"
        },
        {
          "name": "amount",
          "type": "uint256"
        }
      ],
      "outputs": [],
      "restricted_to": "owner",
      "description": "Burns tokens from the specified address, decreasing the total supply."
    },
    {
      "name": "transfer",
      "visibility": "public",
      "inputs": [
        {
          "name": "to",
          "type": "address"
        },
        {
          "name": "amount",
          "type": "uint256"
        }
      ],
      "outputs": [
        {
          "name": "success",
          "type": "bool"
        }
      ],
      "restricted_to": "",
      "description": "Transfers tokens from the caller's account to another account."
    },
    {
      "name": "approve",
      "visibility": "public",
      "inputs": [
        {
          "name": "spender",
          "type": "address"
        },
        {
          "name": "amount",
          "type": "uint256"
        }
      ],
      "outputs": [
        {
          "name": "success",
          "type": "bool"
        }
      ],
      "restricted_to": "",
      "description": "Approves another address to spend a specified amount of tokens on behalf of the caller."
    },
    {
      "name": "transferFrom",
      "visibility": "public",
      "inputs": [
        {
          "name": "from",
          "type": "address"
        },
        {
          "name": "to",
          "type": "address"
        },
        {
          "name": "amount",
          "type": "uint256"
        }
      ],
      "outputs": [
        {
          "name": "success",
          "type": "bool"
        }
      ],
      "restricted_to": "",
      "description": "Transfers tokens from one address to another using an allowance."
    }
  ],
  "events": [
    {
      "name": "Transfer",
      "parameters": [
        {
          "name": "from",
          "type": "address"
        },
        {
          "name": "to",
          "type": "address"
        },
        {
          "name": "value",
          "type": "uint256"
        }
      ]
    },
    {
      "name": "Approval",
      "parameters": [
        {
          "name": "owner",
          "type": "address"
        },
        {
          "name": "spender",
          "type": "address"
        },
        {
          "name": "value",
          "type": "uint256"
        }
      ]
    }
  ],
  "modifiers": []
}