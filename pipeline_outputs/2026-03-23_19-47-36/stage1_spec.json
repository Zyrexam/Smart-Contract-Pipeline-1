{
  "contract_name": "MultiSigWallet",
  "contract_type": "Wallet",
  "description": "A multi-signature wallet where multiple owners must approve transactions.",
  "state_variables": [
    {
      "name": "owners",
      "type": "address[]",
      "visibility": "private",
      "initial_value": "[]"
    },
    {
      "name": "requiredApprovals",
      "type": "uint256",
      "visibility": "private",
      "initial_value": "0"
    },
    {
      "name": "transactions",
      "type": "mapping(uint256 => Transaction)",
      "visibility": "private",
      "initial_value": "{}"
    },
    {
      "name": "transactionCount",
      "type": "uint256",
      "visibility": "private",
      "initial_value": "0"
    }
  ],
  "roles": [
    {
      "name": "owner",
      "permissions": [
        "submitTransaction",
        "approveTransaction",
        "executeTransaction"
      ]
    }
  ],
  "functions": [
    {
      "name": "submitTransaction",
      "visibility": "public",
      "inputs": [
        {
          "name": "destination",
          "type": "address"
        },
        {
          "name": "value",
          "type": "uint256"
        },
        {
          "name": "data",
          "type": "bytes"
        }
      ],
      "outputs": [
        {
          "name": "transactionId",
          "type": "uint256"
        }
      ],
      "restricted_to": "owner",
      "description": "Allows an owner to submit a transaction for approval."
    },
    {
      "name": "approveTransaction",
      "visibility": "public",
      "inputs": [
        {
          "name": "transactionId",
          "type": "uint256"
        }
      ],
      "outputs": [],
      "restricted_to": "owner",
      "description": "Allows an owner to approve a submitted transaction."
    },
    {
      "name": "executeTransaction",
      "visibility": "public",
      "inputs": [
        {
          "name": "transactionId",
          "type": "uint256"
        }
      ],
      "outputs": [],
      "restricted_to": "owner",
      "description": "Executes a transaction if it has received the required number of approvals."
    }
  ],
  "events": [
    {
      "name": "TransactionSubmitted",
      "parameters": [
        {
          "name": "transactionId",
          "type": "uint256"
        },
        {
          "name": "destination",
          "type": "address"
        },
        {
          "name": "value",
          "type": "uint256"
        }
      ]
    },
    {
      "name": "TransactionApproved",
      "parameters": [
        {
          "name": "transactionId",
          "type": "uint256"
        },
        {
          "name": "owner",
          "type": "address"
        }
      ]
    },
    {
      "name": "TransactionExecuted",
      "parameters": [
        {
          "name": "transactionId",
          "type": "uint256"
        }
      ]
    }
  ],
  "modifiers": [
    {
      "name": "onlyOwner",
      "condition": "msg.sender is an owner",
      "description": "Restricts function access to wallet owners."
    },
    {
      "name": "transactionExists",
      "condition": "transaction exists",
      "description": "Ensures the transaction exists before proceeding."
    },
    {
      "name": "notExecuted",
      "condition": "transaction not already executed",
      "description": "Ensures the transaction has not been executed yet."
    },
    {
      "name": "notApproved",
      "condition": "transaction not already approved by this owner",
      "description": "Ensures the transaction has not been approved by the same owner twice."
    }
  ]
}