{
  "contract_name": "MultiSigWallet",
  "contract_type": "wallet",
  "description": "A multi-signature wallet where multiple owners must approve transactions.",
  "name": "",
  "symbol": "",
  "roles": [
    {
      "name": "owner",
      "permissions": [
        "approveTransaction",
        "submitTransaction",
        "revokeApproval"
      ]
    }
  ],
  "state_variables": [
    {
      "name": "owners",
      "type": "address[]",
      "visibility": "private"
    },
    {
      "name": "requiredApprovals",
      "type": "uint",
      "visibility": "private"
    },
    {
      "name": "transactions",
      "type": "Transaction[]",
      "visibility": "private"
    }
  ],
  "functions": [
    {
      "name": "submitTransaction",
      "visibility": "public",
      "inputs": [
        {
          "name": "destination",
          "type": "address"
        },
        {
          "name": "value",
          "type": "uint"
        },
        {
          "name": "data",
          "type": "bytes"
        }
      ],
      "outputs": [
        {
          "name": "transactionId",
          "type": "uint"
        }
      ],
      "restricted_to": "owner",
      "description": "Allows an owner to submit a transaction for approval."
    },
    {
      "name": "approveTransaction",
      "visibility": "public",
      "inputs": [
        {
          "name": "transactionId",
          "type": "uint"
        }
      ],
      "outputs": [],
      "restricted_to": "owner",
      "description": "Allows an owner to approve a submitted transaction."
    },
    {
      "name": "revokeApproval",
      "visibility": "public",
      "inputs": [
        {
          "name": "transactionId",
          "type": "uint"
        }
      ],
      "outputs": [],
      "restricted_to": "owner",
      "description": "Allows an owner to revoke their approval for a transaction."
    },
    {
      "name": "executeTransaction",
      "visibility": "public",
      "inputs": [
        {
          "name": "transactionId",
          "type": "uint"
        }
      ],
      "outputs": [],
      "restricted_to": "owner",
      "description": "Executes a transaction if it has enough approvals."
    },
    {
      "name": "getTransactionDetails",
      "visibility": "public",
      "inputs": [
        {
          "name": "transactionId",
          "type": "uint"
        }
      ],
      "outputs": [
        {
          "name": "destination",
          "type": "address"
        },
        {
          "name": "value",
          "type": "uint"
        },
        {
          "name": "data",
          "type": "bytes"
        },
        {
          "name": "executed",
          "type": "bool"
        }
      ],
      "restricted_to": "",
      "description": "Returns the details of a specific transaction."
    }
  ],
  "events": [
    {
      "name": "TransactionSubmitted",
      "parameters": [
        {
          "name": "transactionId",
          "type": "uint"
        }
      ]
    },
    {
      "name": "TransactionApproved",
      "parameters": [
        {
          "name": "transactionId",
          "type": "uint"
        },
        {
          "name": "owner",
          "type": "address"
        }
      ]
    },
    {
      "name": "TransactionExecuted",
      "parameters": [
        {
          "name": "transactionId",
          "type": "uint"
        }
      ]
    },
    {
      "name": "ApprovalRevoked",
      "parameters": [
        {
          "name": "transactionId",
          "type": "uint"
        },
        {
          "name": "owner",
          "type": "address"
        }
      ]
    }
  ]
}